# Supabase project URL — Supabase dashboard → Project Settings → API → Project URL
# Safe to expose to the browser (public). Leave BOTH Supabase vars blank to
# run in local-only mode (localStorage; no sync, no account).
#
# Remote sync requires signing in with EMAIL (magic link). Configure the
# email provider + Site URL + Redirect URLs in the Supabase dashboard — see
# PERSISTENCE_QA.md. Anonymous sign-ins are NOT used and should stay disabled.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key — Supabase dashboard → Project Settings → API → anon public key
# Safe to expose to the browser (public). Row-level security protects data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Anthropic API key — https://console.anthropic.com/settings/keys
# SERVER-ONLY. Never exposed to the browser; used only by app/api/ai.
# If blank, the AI route returns deterministic mock output.
ANTHROPIC_API_KEY=

# Optional: Anthropic model id used by the AI route (defaults to claude-sonnet-5)
ANTHROPIC_MODEL=
